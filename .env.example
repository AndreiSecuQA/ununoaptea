# ============================================================
# Calendar: Vorbim la UNU NOAPTEA — environment variables
# Copy to .env and fill in real values.
# ============================================================

# --- App ---
# Railway deployments should stay on `production`. Use `development` only local.
APP_ENV=production
APP_SECRET_KEY=change-me-to-64-random-chars
# Railway: setează la ${{ununoaptea-frontend.RAILWAY_PUBLIC_DOMAIN}} (cu https://)
FRONTEND_URL=https://ununoaptea-frontend.up.railway.app
# Railway: setează la ${{ununoaptea-backend.RAILWAY_PUBLIC_DOMAIN}} (cu https://)
API_BASE_URL=https://ununoaptea-backend.up.railway.app
# Extra origins pentru CORS (comma-separated), ex pentru staging:
# CORS_EXTRA_ORIGINS=https://staging.calendar.ununoaptea.com,https://preview.example.com
CORS_EXTRA_ORIGINS=

# --- Database ---
# Railway: foloseste reference variable `${{Postgres.DATABASE_URL}}` —
# prefix-ul `postgresql://` e auto-convertit la `postgresql+asyncpg://` de
# config.py. NU lasa placeholder-ul `user:pass@db:5432` in productie.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DIGITAL_PRICE_ID=price_...

# --- S3 (AWS or Cloudflare R2) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=unu-noaptea-calendars
S3_REGION=eu-central-1

# --- Email (Resend or SendGrid) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=calendare@ununoaptea.com
EMAIL_FROM_NAME="Unu Noaptea"

# --- Admin ---
ADMIN_EMAIL=andrei.s3cu@gmail.com
ADMIN_PASSWORD_HASH=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Business ---
PROMO_CODE_NEXT_YEAR=VU1P3
JWT_DOWNLOAD_TOKEN_EXPIRE_DAYS=90
PDF_S3_PRESIGNED_URL_EXPIRE_HOURS=24
CALENDAR_PRICE_EUR=15

# --- Demo mode ---
# Set DEMO_MODE=true to bypass Stripe (founder demos). PDFs are saved under
# /tmp/unu_noaptea_demo_pdfs/ instead of S3 and served directly. Also set
# VITE_DEMO_MODE=true in the frontend build so Step 7 copy matches.
DEMO_MODE=true

# --- Rate limiting ---
RATE_LIMIT_CREATE_ORDER=5/minute
RATE_LIMIT_ORDER_STATUS=20/minute
